{
  "name": "isuzu-cotizador",
  "version": "1.0.0",
  "description": "Sistema de cotización Isuzu - Camiones ELF y Forward",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "backend": "npm run start:dev -w backend",
    "backend:build": "npm run build -w backend",
    "frontend": "npm run dev -w frontend",
    "frontend:build": "npm run build -w frontend",
    "db:migrate": "cd backend && npm run migration:run",
    "db:migrate:generate": "npm run migration:generate -w backend",
    "seed": "npm run seed -w backend",
    "db:create-clientes": "node scripts/run-migration-clientes.js",
    "test": "npm run test -w backend && npm run test -w frontend",
    "test:backend": "npm run test -w backend",
    "test:frontend": "npm run test -w frontend",
    "test:api": "node scripts/test-api.js",
    "test:full": "node scripts/test-full.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
