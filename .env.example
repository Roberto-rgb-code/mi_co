# Copiar este archivo a .env y completar los valores
# En Windows: copy .env.example .env

# Base de datos PostgreSQL (Railway u otro proveedor)
DATABASE_URL=postgresql://postgres:password@host:puerto/railway

# Puerto (Railway asigna automático en deploy)
PORT=3000

# Entorno (production en Railway)
NODE_ENV=development

# --- Asistente (ChatGPT / OpenAI) ---
# Crea tu clave en: https://platform.openai.com/api-keys
# En Railway: Variables → New Variable → OPENAI_API_KEY
OPENAI_API_KEY=sk-...
# Modelo económico recomendado (barato y suficiente para chat):
OPENAI_MODEL=gpt-4o-mini

# Ilustración tipo “render” en el asistente (tarimas/carga): DALL·E 3, misma API que arriba.
# Costo aprox. USD 0.04 (standard) o 0.08 (hd) por imagen. Sin esto, solo diagrama SVG técnico.
# ENABLE_ASSISTANT_DALLE_IMAGE=true
# DALLE_IMAGE_MODEL=dall-e-3
# DALLE_IMAGE_QUALITY=standard
